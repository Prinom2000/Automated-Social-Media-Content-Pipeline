        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-image:generateContent?key=AIzaSyBnyeTBG82bPrkPbIgKoQMq4cgA7UQ7hlk",
        "sendHeaders": true,
